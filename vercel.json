{
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/public/(.*)",
            "dest": "/public/$1"
        },
        {
            "src": "/(config|app)/.*",
            "status": 403,
            "dest": "/"
        },
        {
            "src": "/(?!index\\.php)(.*)",
            "dest": "/api/index.php?page=$1"
        },
        {
            "src": "/index\\.php",
            "dest": "/api/index.php"
        }
    ]
}